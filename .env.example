# .env.example
# Complete environment configuration template for Docker deployment.
# Copy this file to .env and fill in your actual values before running `docker-compose up -d`.

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── URLs ───────────────────────────────────────────────────────────────────
# FRONTEND_URL: The domain where your Vue/React app is hosted. Used by backend for CORS and OAuth redirects.
# Example: https://eventhub.yourdomain.com
FRONTEND_URL=http://localhost:5173

# VITE_API_URL: The URL the frontend uses to talk to the backend.
# In a perfect Docker deploy, Nginx serves the frontend AND proxies /api to the backend.
# So this should literally just be "/api" for production, or "http://localhost:3003/api" for local dev.
VITE_API_URL=/api

# ─── Database ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/eventhub?retryWrites=true&w=majority

# ─── Security/Auth ─────────────────────────────────────────────────────────
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# ─── Google OAuth ──────────────────────────────────────────────────────────
# Set these up at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Stripe Payments ───────────────────────────────────────────────────────
# Get these at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_test_...

# ─── Cloudinary (Image Uploads) ───────────────────────────────────────────
# Get these at: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email Configuration (SMTP) ────────────────────────────────────────────
# If using Gmail, you MUST use an App Password, not your real password.
# Setup here: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
EMAIL_USERNAME=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password_here
